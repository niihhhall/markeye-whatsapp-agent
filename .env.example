# === Markeye Mark AI SDR: Configuration ===
# Environment: production or development
ENVIRONMENT=production
DEBUG=false
AGENT_NAME=Mark

# === LLM Providers (Highly recommended to have fallback) ===
# Primay model for discovery and booking
GROQ_API_KEY=gsk_xxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Secondary model for summarization and cheap tasks
GEMINI_API_KEY=AIzaSy_xxxxx
GEMINI_MODEL=gemini-1.5-flash

# Fallback provider
CEREBRAS_API_KEY=csk-xxxxx
CEREBRAS_MODEL=llama3.1-70b

# === WhatsApp Messaging ===
# Messaging Provider Configuration
# ------------------------------
# Default provider for outgoing messages. 
# Values: 'baileys' (local dev / bridge) or 'whatsapp_cloud' (official Meta API).
# Note: If ENVIRONMENT=production, 'baileys' is automatically blocked for safety.
MESSAGING_PROVIDER=whatsapp_cloud
AUTH_MODE=qr               # "qr" or "pairing"
PAIRING_PHONE_NUMBER=      # e.g. 447123456789 (no '+' or zeros)
SALES_PHONE_NUMBER=        # Target for [ESCALATE] trigger


BAILEYS_AUTH_DIR=./baileys-service/sessions

# WhatsApp Cloud API (Legacy/Fallback fallback)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=markeye_verify
WHATSAPP_APP_SECRET=your_meta_app_secret_here

# Security
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# === Database & State ===
# Supabase project URL and keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Redis connection (Upstash supported)
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Third-Party Integrations ===
# Booking link (Cal.com recommended — Calendly is deprecated):
CALCOM_LINK=https://cal.com/your-username/free-discovery-call
# CALENDLY_LINK=  # Only set if still using Calendly

# === Monitoring (Optional) ===
SENTRY_DSN=

# === Conversation Behavior Tuning ===
# Seconds to wait for user to stop typing
INPUT_BUFFER_SECONDS=5
# Rate limiting (e.g. max 3 triggers/10 sec) is enforced in webhook.py
# Speed of the typing indicator (seconds per character)
TYPING_DELAY_PER_CHAR=0.03
# Delay between message chunks if reply is split
CHUNK_DELAY_SECONDS=1.5
# Max follow-up attempts for stale leads
MAX_FOLLOWUPS=3
# Sliding window: number of messages to keep before summarization
MAX_CONTEXT_MESSAGES=10
